# Copy to .env and adjust for your server / Portainer stack.
# All commands below run inside Docker; host Bun is not required.

# Container timezone for the 08:00 daily schedule
TZ=Europe/Madrid

# Cron expression in UTC (default: every day at 08:00 UTC).
# In-process Bun.cron uses UTC; TZ below only affects scraper/logs, not this schedule.
CRON_SCHEDULE=0 8 * * *

# Run scraper immediately when the scheduler container starts
RUN_ON_START=false

# Playwright headless mode
HEADLESS=true

# ---
# Docker usage (from project root):
#
# Build image:
#   docker compose build
#
# Start daily scheduler (08:00):
#   docker compose up -d scheduler
#
# Run one-off scrape now:
#   docker compose --profile manual run --rm scrape
#
# View logs:
#   docker compose logs -f scheduler
#
# Portainer: deploy docker-compose.yml as a stack and mount ./data for persisted prices.
